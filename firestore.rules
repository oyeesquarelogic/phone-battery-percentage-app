rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: notes
    // Fields:
    //   - userId: string (required) - Owner UID
    //   - text: string (required, max 1000 chars) - Note content
    //   - createdAt: timestamp (required) - Creation time
    //   - batteryLevel: number (required, 0-100) - Battery level
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidNote(data) {
      return data.keys().hasAll(['userId', 'text', 'createdAt', 'batteryLevel']) &&
             data.keys().hasOnly(['userId', 'text', 'createdAt', 'batteryLevel']) &&
             data.userId is string &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.createdAt is timestamp &&
             data.batteryLevel is number && data.batteryLevel >= 0 && data.batteryLevel <= 100;
    }

    match /notes/{noteId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && 
                      isValidNote(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
